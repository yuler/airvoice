---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/react/Header';
import Hero from '../../components/react/Hero';
import Features from '../../components/react/Features';
import HowItWorks from '../../components/react/HowItWorks';
import GetStarted from '../../components/react/GetStarted';
import Footer from '../../components/react/Footer';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Airvoice — 手机说话，电脑打字"
  description="局域网语音桥接工具，支持 Mac 和 Linux。无云端、无账号。"
  lang="zh"
>
  <Header lang="zh" base={base} active="home" client:load />
  <Hero lang="zh" base={base} />
  <Features lang="zh" />
  <HowItWorks lang="zh" />
  <GetStarted lang="zh" base={base} />
  <Footer lang="zh" base={base} />
</BaseLayout>
