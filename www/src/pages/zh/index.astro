---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/react/Header';
import Hero from '../../components/react/Hero';
import Features from '../../components/react/Features';
import WorksEverywhere from '../../components/react/WorksEverywhere';
import Footer from '../../components/react/Footer';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Airvoice — 与你的设备沟通。简单直接。"
  description="局域网语音桥接工具，支持 Windows、macOS、Linux；手机端支持 Android 和 iOS。无云端、无账号、无需联网。"
  lang="zh"
>
  <Header lang="zh" base={base} active="home" currentPath={Astro.url.pathname} client:load />
  <Hero lang="zh" base={base} client:load />
  <Features lang="zh" client:load />
  <WorksEverywhere lang="zh" />
  <Footer lang="zh" />
</BaseLayout>
